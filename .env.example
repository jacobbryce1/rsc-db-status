RSC_DOMAIN=your-account.my.rubrik.com
RSC_CLIENT_ID=your-client-id-here
RSC_CLIENT_SECRET=your-client-secret-here
DB_STATUS_WORK_DIR=./db_status_work

# Logging: INFO (default) | DEBUG | WARNING | ERROR
# Set LOG_FILE to write logs to a file in addition to the console
LOG_LEVEL=INFO
# LOG_FILE=db_status.log

# Worker / page size overrides — use these to calm down aggressive API usage.
# The tool auto-selects a scale profile, but you can cap both values here.
# Example for a restrictive RSC instance (like Dave's):
# MAX_PAGE_SIZE=100
# MAX_WORKERS=1
# REQUEST_TIMEOUT=120   # seconds per API call (default: 120)
# MIN_PAGE_SIZE=25      # floor for adaptive page-size reduction (default: 25)

# Disk cache — parsed records are AES-encrypted and cached after each run.
# Subsequent runs load from cache (skipping the API fetch) until TTL expires.
# Requires the cryptography package (included in requirements.txt).
CACHE_TTL_HOURS=12
# CACHE_FILE=.db_status_cache.bin
# CACHE_KEY_FILE=.db_status_cache.key
